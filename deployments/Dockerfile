FROM golang:1.21-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o astro-scheduler ./cmd/server

FROM alpine:latest

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=builder /app/astro-scheduler .
COPY configs/config.yaml configs/config.yaml

RUN mkdir -p /app/data/archive

EXPOSE 8080

CMD ["./astro-scheduler", "--config", "configs/config.yaml"]
